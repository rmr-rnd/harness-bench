# Absolute path to the project directory, as the Docker daemon sees it.
# Linux/Mac: run  echo "HARNESS_HOST_WORK_DIR=$(pwd)" >> docker/.env
# Windows (Docker Desktop / WSL2): use the daemon mount path — NOT C:\... or C:/...
#   a drive-letter path contains ':' which collides with compose's src:dst volume syntax.
#   Convert  D:\foo\harness_bench  ->  /run/desktop/mnt/host/d/foo/harness_bench
#   (drive letter lowercase, '\' -> '/'). See docs/configuration.md.
HARNESS_HOST_WORK_DIR=/absolute/path/to/harness_bench

DB_PASSWORD=harness_dev
